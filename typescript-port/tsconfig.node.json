{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "outDir": "./dist-main",
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "$shared": ["./shared"],
      "$shared/*": ["./shared/*"]
    }
  },
  "include": [
    "main/**/*.ts",
    "main/**/*.js",
    "shared/**/*.ts",
    "shared/**/*.js",
    "main.ts",
    "preload.ts",
    "svelte.config.js",
    "vite.config.ts"
  ]
}
